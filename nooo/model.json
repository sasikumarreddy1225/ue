                        "component": "text",
                        "name": "label",
                        "label": "Enter Label",
                        "valueType": "string"
                    },
                    {
                        "component": "select",
                        "name": "type",
                        "label": "Link Type",
                        "valueType": "string",
                        "value": "webLink",
                        "options": [
                            {
                                "name": "Document Link",
                                "value": "docLink"
                            },
                            {
                                "name": "Web Link",
                                "value": "webLink"
                            }
                        ]
                    },
                    {
                        "component": "aem-content",
                        "name": "path",
                        "label": "Select Document",
                        "valueType": "string",
                        "condition": {
                            "===": [
                                {
                                    "var": "type"
                                },
                                "docLink"
